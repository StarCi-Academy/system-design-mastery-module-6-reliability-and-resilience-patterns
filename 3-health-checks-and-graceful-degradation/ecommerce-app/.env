# App runtime
# (EN: App runtime)
PORT=3000

# Graceful degradation threshold in MB (`/products` endpoint).
# (EN: Graceful degradation threshold in MB for `/products`.)
DEGRADE_HEAP_THRESHOLD_MB=120

# Terminus memory indicator threshold in bytes (`/health` endpoint).
# (EN: Terminus memory indicator threshold in bytes for `/health`.)
HEALTH_HEAP_THRESHOLD_BYTES=209715200

# Simulated database indicator status: `up` or `down`.
# (EN: Simulated database indicator status: `up` or `down`.)
DATABASE_HEALTH_STATUS=up
